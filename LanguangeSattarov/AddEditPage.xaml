<Page x:Class="LanguangeSattarov.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LanguangeSattarov"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage" FontFamily="Comic Sans MS">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Name="IDPanel" Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="ID" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding ID}" IsEnabled="False" Height="30" Width="250"></TextBox>
        </StackPanel>
        <StackPanel  Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Фамилия" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding FirstName}" Height="30" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Имя" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding LastName}" Height="30" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Отчество" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding Patronymic}" Height="30" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Email" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding Email}" Height="30" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="5" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Телефон" FontSize="15" Height="20" Width="150"></TextBlock>
            <TextBox Text="{Binding Phone}" Height="30" Width="250"></TextBox>
        </StackPanel>
        <StackPanel Grid.Row="6" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Дата рождения" FontSize="15" Height="20" Width="150"></TextBlock>
            <DatePicker SelectedDate="{Binding Birthday}" Grid.Column="0" Grid.Row="6" Height="30" Width="200" FontSize="20" Name="Date" HorizontalAlignment="Left"></DatePicker>
        </StackPanel>
        <StackPanel Grid.Row="7" Grid.Column="0" Orientation="Horizontal">
            <TextBlock Text="Пол" FontSize="15" Height="20" Width="150"></TextBlock>
            <StackPanel Orientation="Vertical">
                <RadioButton Content="Женский" GroupName="Sort" Width="300" FontSize="20" Checked="RButtonj_Checked_1" Name="RButtonj"></RadioButton>
                <RadioButton Content="Мужской" GroupName="Sort" Width="300" FontSize="20" Checked="RButtonm_Checked" Name="RButtonm"></RadioButton>

            </StackPanel>
           
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="2" Grid.RowSpan="5" HorizontalAlignment="Center">
            <TextBlock Text="Фото" FontSize="15" Margin="0,0,0,10"></TextBlock>
            <Image Name="LogoImage" Height="150" Width="150" Stretch="Uniform" >
                <Image.Source>
                    <Binding Path="PhotoPath" TargetNullValue="res/picture.png"></Binding>
                </Image.Source>
            </Image>
            <Button Content="Изменить" Name="ChangePictureBtn" Click="ChangePictureBtn_Click"></Button>

        </StackPanel>


        <Button Name="SaveButton" Content="Сохранить" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Click="SaveButton_Click"></Button>
    </Grid>
</Page>
